+class LagunaDenseFFN(nn.Module):
+    """Dense replacement for the routed MoE block in the DENSIFIED Laguna student."""
+    def __init__(self, config, quant_config=None, prefix="", enable_eplb=False):
+        super().__init__()
+        h = config.hidden_size
+        routed = config.num_experts_per_tok * config.moe_intermediate_size
+        self.routed_dense = LagunaMLP(h, routed, config.hidden_act, quant_config,
+                                      prefix=f"{prefix}.routed_dense")
+        self.shared_experts = LagunaMLP(h, config.shared_expert_intermediate_size,
+                                        config.hidden_act, quant_config,
+                                        prefix=f"{prefix}.shared_experts")
+        self.scale = float(getattr(config, "moe_routed_scaling_factor", 1.0))
+    def forward(self, x):
+        return self.routed_dense(x) * self.scale + self.shared_experts(x)
